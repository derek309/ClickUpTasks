{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ClickUpTasks Helper",
  "version": "0.1.0",
  "identifier": "com.clickuplocal.clickuptasks-helper",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "settings",
        "title": "ClickUpTasks Helper — Settings",
        "url": "index.html",
        "width": 420,
        "height": 240,
        "resizable": false,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["clickuptasks"]
      }
    }
  }
}
