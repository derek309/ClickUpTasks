{
  "manifest_version": 3,
  "name": "ClickUpTasks Clipper",
  "version": "1.2.0",
  "description": "Create or update a ClickUpTasks task from any page — a Gmail email or a screenshot of a website you're reviewing.",
  "permissions": ["storage", "sidePanel", "activeTab"],
  "host_permissions": ["https://mail.google.com/*", "https://clickuptasks.vercel.app/*"],
  "action": {},
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://mail.google.com/*"],
      "js": ["content.js"]
    }
  ],
  "options_page": "options.html"
}
